# Local dev: copy this file to .env and fill in your real values.
# .env is gitignored — never commit real secrets.
#
# Production (Vercel): set these in the Vercel dashboard under
# Project Settings > Environment Variables.

# Email (Resend)
RESEND_API_KEY=

# Admin login
# Choose any strong password for the admin panel (/admin.html)
ADMIN_PASSWORD=
# Any long random string used to sign JWTs — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=

# Cloudinary (image storage for the gallery)
# Sign up free at https://cloudinary.com — get these from your dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
